# --- Banco de Dados Aiven Cloud ---
AVNADMIN_PASSWORD=AX
AVNADMIN_HOST=X
AVNADMIN_PORT=X
AVNADMIN_DATABASE=X

# --- BANCO DE DADOS LOCAL (Desativado - Usando Aiven) ---
# MYSQL_ROOT_PASSWORD=sua_senha_mestra_aqui
# GHOST_DB_PASSWORD=sua_senha_do_usuario_ghost
# GHOST_DB_NAME=ghost_db
# GHOST_DB_USER=ghost

# --- CONFIGURAÇÕES DO BLOG (Ghost) ---
# A URL deve incluir o https://
GHOST_URL=https://blog.seu-dominio.site
GHOST_ADMIN_URL=https://blog.seu-dominio.site/ghost

# --- ACESSO INICIAL DO ADMIN ---
# Credenciais para o primeiro login no painel /ghost
GHOST_ADMIN_EMAIL=admin@seu-dominio.local
GHOST_ADMIN_PASSWORD=SenhaForte2026!

# --- CONFIGURAÇÕES DE E-MAIL (SMTP) ---
# Exemplo usando Brevo/Sendinblue
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=seu_usuario_smtp_aqui
SMTP_PASS=sua_chave_api_ou_senha_smtp
MAIL_FROM="Nome do Blog <seu-email@dominio.com>"
